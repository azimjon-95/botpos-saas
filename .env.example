# ─── DATABASE ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/botpos_saas
REDIS_URL=redis://localhost:6379

# ─── SHIFRLASH KALITI (AES-256) — MAJBURIY ──────────────────────────────────
# Yaratish: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=your_64_char_hex_key_here

# ─── ADMIN JWT — MAJBURIY ────────────────────────────────────────────────────
# Yaratish: openssl rand -base64 48
ADMIN_JWT_SECRET=change_this_to_very_long_random_string_min_32_chars

# ─── ADMIN EMAIL ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@botpos.uz

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=6060
TZ=Asia/Tashkent

# ─── WEBAPP ──────────────────────────────────────────────────────────────────
WEBAPP_BASE_URL=https://botpos.uz

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
API_RATE_LIMIT=100
BOT_RATE_LIMIT=30

# ─── BILLING NOTIFIER ────────────────────────────────────────────────────────
# Admin ga ogohlantirish yuboruvchi bot (ixtiyoriy — alohida bot)
ADMIN_NOTIFICATION_BOT_TOKEN=
# Admin ogohlantirish chat ID yoki user ID
ADMIN_NOTIFICATION_CHAT_ID=

# ─── MARKAZIY OPENAI ─────────────────────────────────────────────────────────
# Barcha do'konlar uchun bitta kalit (do'konlardan talab qilinmaydi)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# ─── BACKUP ──────────────────────────────────────────────────────────────────
# Har kuni 23:00 da butun DB backup shu chat ga yuboriladi
# Admin guruh yoki shaxsiy chat ID
BACKUP_CHAT_ID=-1001234567890
