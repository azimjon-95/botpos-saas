# ══════════════════════════════════════════
#   BOT·POS Backend — .env namunasi
#   Nusxa oling: copy .env.example .env
#   Keyin to'ldiring va server qayta ishga tushing
# ══════════════════════════════════════════

# ── Server ────────────────────────────────
PORT=6060
NODE_ENV=development

# ── MongoDB ───────────────────────────────
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/botpos?retryWrites=true&w=majority

# ── Admin panel LOGIN ─────────────────────
# admin yaratish: node scripts/create-admin.js
ADMIN_EMAIL=admin@botpos.uz
ADMIN_PASSWORD=your_strong_password_here

# Admin JWT
ADMIN_JWT_SECRET=change_this_to_random_32_chars_string

# ── Shifrlash ─────────────────────────────
# Aynan 32 ta belgi bo'lsin!
MASTER_ENCRYPTION_KEY=12345678901234567890123456789012

# ── URLs ──────────────────────────────────
SERVER_URL=http://localhost:6060
WEBAPP_BASE_URL=http://localhost:8081

# ── Redis (ixtiyoriy) ─────────────────────
# REDIS_URL=redis://localhost:6379

# ── OpenAI (ixtiyoriy, AI xususiyati uchun) ──
# OPENAI_API_KEY=sk-...
