# ─── DATABASE ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/botpos_saas
REDIS_URL=redis://localhost:6379

# ─── SHIFRLASH KALITI (AES-256) — MAJBURIY ──────────────────────────────────
# Yaratish: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=your_64_char_hex_key_here

# ─── ADMIN JWT — MAJBURIY ────────────────────────────────────────────────────
# Yaratish: openssl rand -base64 48
ADMIN_JWT_SECRET=change_this_to_very_long_random_string_min_32_chars

# ─── ADMIN EMAIL ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@botpos.uz

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=6060
TZ=Asia/Tashkent

# ─── WEBAPP ──────────────────────────────────────────────────────────────────
WEBAPP_BASE_URL=https://botpos.uz

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
API_RATE_LIMIT=100
BOT_RATE_LIMIT=30
