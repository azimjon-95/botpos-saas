# BOT·POS Backend — Lokal muhit
# Bu faylni .env ga nusxa oling va to'ldiring

PORT=6060

# MongoDB Atlas — o'zingizning URI
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/botpos?retryWrites=true&w=majority

# Redis (ixtiyoriy, lokal test uchun bo'sh qoldiring)
# REDIS_URL=redis://localhost:6379

# Telegram Bot tokenlar (har bir do'kon uchun DB da saqlanadi)
# Master token: botpos super admin boti
MASTER_BOT_TOKEN=

# Encryption
MASTER_ENCRYPTION_KEY=your-32-char-secret-key-here-ok!

# Admin panel
ADMIN_JWT_SECRET=your-admin-jwt-secret

# WebApp base URL (lokal test uchun)
SERVER_URL=http://localhost:6060
WEBAPP_BASE_URL=http://localhost:8081

# Telegram WebApp URL (lokal test uchun ngrok ishlatish mumkin)
# WEBAPP_BASE_URL=https://YOUR_NGROK.ngrok.io
